# ─────────────────────────────────────────
#  Backend .env.example
#  Copy to .env and fill in real values
# ─────────────────────────────────────────

# ── Application ──────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# ── Database (PostgreSQL) ─────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=croply_user
DB_PASSWORD=croply_secret_password
DB_NAME=croply_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# ── JWT Auth ─────────────────────────────
JWT_SECRET=CHANGE_ME_super_secret_jwt_key_256bits
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_super_secret_refresh_key
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Throttle / Rate Limiting ──────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─────────────────────────────────────────
#  Backend .env.example
#  Copy to .env and fill in real values
# ─────────────────────────────────────────

# ── Application ──────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Swagger / OpenAPI ────────────────────
# true|false — si se omite: habilitado fuera de production
SWAGGER_ENABLED=true

# ── Database (PostgreSQL) ─────────────────
# Local (app fuera de Docker, DB en compose): localhost
# App dentro de la misma red Docker: nombre del servicio (ej. db)
DB_HOST=localhost
DB_PORT=5432
DB_USER=croply_admin
DB_PASSWORD=croply_password
DB_NAME=croply_db
DB_SYNCHRONIZE=true
DB_LOGGING=true

# ── JWT Auth ─────────────────────────────
JWT_SECRET=CHANGE_ME_super_secret_jwt_key_256bits
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_super_secret_refresh_key
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Throttle / Rate Limiting ──────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
